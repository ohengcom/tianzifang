{
  "name": "tianzifang-crowd",
  "version": "1.4.2",
  "description": "Tianzifang crowd data collection and analysis",
  "type": "module",
  "dependencies": {
    "node-cron": "^4.6.0",
    "pg": "^8.22.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node --env-file=.env main.js --schedule",
    "collect": "node --env-file=.env main.js",
    "init": "node --env-file=.env main.js --init",
    "summary": "node --env-file=.env main.js --summary",
    "report:yesterday": "node --env-file=.env main.js --report-yesterday",
    "query": "node --env-file=.env analysis/query.js",
    "v2:init": "node --env-file=.env analysis/v2.js init",
    "v2:collect:amap-weather": "node --env-file=.env analysis/v2.js collect-amap-weather",
    "v2:import-crowd-anchors": "node --env-file=.env analysis/v2.js import-crowd-anchors data/historical_crowd_anchors.json",
    "v2:report-html": "node --env-file=.env analysis/v2.js report-html reports/tianzifang-crowd-report.html",
    "v2:derive": "node --env-file=.env analysis/v2.js derive",
    "v2:summary": "node --env-file=.env analysis/v2.js summary",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "check": "npm run lint && npm run test"
  }
}
