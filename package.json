{
  "name": "tianzifang-crowd",
  "version": "1.2.0",
  "description": "Tianzifang crowd data collection and analysis",
  "type": "module",
  "dependencies": {
    "node-cron": "^4.6.0",
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "start": "node --env-file=.env main.js --schedule",
    "collect": "node --env-file=.env main.js",
    "init": "node --env-file=.env main.js --init",
    "summary": "node --env-file=.env main.js --summary",
    "report:yesterday": "node --env-file=.env main.js --report-yesterday",
    "query": "node --env-file=.env analysis/query.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "vitest run",
    "check": "npm run lint && npm run test"
  }
}
